{
  "manifest_version": 3,
  "name": "Iranti Memory",
  "version": "1.0.0",
  "description": "Adds persistent memory to Claude and ChatGPT",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chat.openai.com/*",
    "http://localhost:3001/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
