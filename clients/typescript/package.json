{
  "name": "@iranti/sdk",
  "version": "0.2.4",
  "description": "TypeScript HTTP client for the Iranti REST API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nfemmanuel/iranti.git"
  },
  "homepage": "https://github.com/nfemmanuel/iranti",
  "bugs": {
    "url": "https://github.com/nfemmanuel/iranti/issues"
  }
}
